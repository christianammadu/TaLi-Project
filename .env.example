# TaLi — environment configuration. Copy to `.env` and fill in real values.
# Never commit the real .env (it is gitignored).

# --- Flask ---
# Generate a strong random value for production, e.g. `python -c "import secrets;print(secrets.token_hex(32))"`
SECRET_KEY=change-me-in-production

# --- WhatsApp / Meta Cloud API ---
ACCESS_TOKEN=
PHONE_NUMBER_ID=
VERIFY_TOKEN=
# App Secret from the Meta App dashboard — REQUIRED in production so inbound
# webhooks are HMAC-verified (X-Hub-Signature-256). If unset, signatures are
# NOT verified and a warning is logged.
META_APP_SECRET=

# --- MySQL database ---
DB_HOST=localhost
DB_USER=
DB_PASSWORD=
DB_NAME=tali

# --- Authentication ---
APP_BASE_URL=http://localhost:5000
SESSION_DURATION_HOURS=72
OTP_EXPIRY_MINUTES=10
TOKEN_EXPIRY_MINUTES=5
OTP_TEMPLATE_NAME=verification_code
# Must match the language of your approved WhatsApp template (e.g. en or en_US).
OTP_TEMPLATE_LANG=en_US
# If the template send fails, also try a plain-text OTP (only delivers within
# WhatsApp's 24h window — handy for testing). Set false to disable.
OTP_TEXT_FALLBACK=true
# DEV ONLY (default off). Set true to proceed to the OTP step even if WhatsApp
# delivery fails (the code is printed to the server console for testing). NEVER
# enable in production — it stops real users getting codes and logs OTP values.
OTP_DEV_BYPASS=false

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_INPUT_COST_PER_MILLION=0.150
OPENAI_OUTPUT_COST_PER_MILLION=0.600

# --- Multi-provider model routing (WP-01) ---
# AI/ML API ($10 credits) — frontier reasoning + low-confidence escalation. OpenAI-compatible.
AIML_API_KEY=
AIML_BASE_URL=https://api.aimlapi.com/v1
AIML_CFO_MODEL=gpt-4o
AIML_ESCALATION_MODEL=gpt-4o
# Featherless ($25 credits) — high-volume open-source workers. OpenAI-compatible.
FEATHERLESS_API_KEY=
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
FEATHERLESS_INTAKE_MODEL=Qwen/Qwen2.5-72B-Instruct
FEATHERLESS_COMPLIANCE_MODEL=mistralai/Mistral-Small-24B-Instruct-2501
# OpenAI (keys above) is the terminal fallback provider.
# Optional per-process spend ceiling in USD (0 = unlimited) so a demo run can't exhaust credits.
MODEL_ROUTER_SPEND_CEILING_USD=0

# --- Band platform (WP-02) ---
# "stub" = in-process fire-and-forget connector (offline dev/tests); "live" = real band.ai.
BAND_BACKEND=stub
# band.ai / Thenvoi endpoints (note the THENVOI_ prefix — the code is named thenvoi).
THENVOI_REST_URL=https://app.band.ai/
THENVOI_WS_URL=wss://app.band.ai/api/v1/socket/websocket
BAND_ROOM_ID=
# Per-agent credentials — register each remote agent on app.band.ai (Pro) and paste agent_id + X-API-Key.
BAND_INTAKE_AGENT_ID=
BAND_INTAKE_API_KEY=
BAND_LEDGER_AGENT_ID=
BAND_LEDGER_API_KEY=
BAND_CFO_AGENT_ID=
BAND_CFO_API_KEY=
BAND_COMPLIANCE_AGENT_ID=
BAND_COMPLIANCE_API_KEY=
